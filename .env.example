# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: require this header (x-import-secret) on /api/import, /api/google/*
IMPORT_SECRET=

# Google: service account JSON (single-line string or multi-line — Vercel often uses one line)
# Share your Sheet with the service account email (…@….iam.gserviceaccount.com) as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Spreadsheet ID from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SPREADSHEET_ID=

# Tab and top-left cell to overwrite (create a sheet tab named Summary)
GOOGLE_SHEETS_RANGE=Summary!A1
